# Copy to ".env" in this folder (next to docker-compose.yml). The file is gitignored (see repo .gitignore).
# The API and Worker load DotNetEnv on startup: variables here become .NET environment variables
# (nested keys: use __ for :, e.g. ConnectionStrings__DefaultConnection).
# Docker Compose also uses this file for ${VAR} substitution in docker-compose.yml.
# Do not put secrets in appsettings.json; keep them here or in the deployment environment.
#
# --- Alias map (at startup, only if the left-hand key is empty) ---
# The API/Worker set nested keys from the Docker-style name on the right, so you can use either form:
#   STRIPE_SECRET_KEY  ->  Stripe__SecretKey
#   STRIPE_PUBLISHABLE_KEY  ->  Stripe__PublishableKey
#   SMTP_HOST, SMTP_PORT, ...  ->  Smtp__Host, Smtp__Port, ...
#   DEMO_NOTIFICATION_EMAIL  ->  DemoSeed__NotificationEmail
# Prefer the nested (Stripe__*) form in production; STRIPE_* keeps docker-compose and dotnet run in sync with one file.
#
# --- API + database ---
# SQL Server (local or Docker). Required for the API to start. Example (adjust server/database name):
# ConnectionStrings__DefaultConnection=Server=localhost;Database=220245;Trusted_Connection=True;MultipleActiveResultSets=True;TrustServerCertificate=True
ConnectionStrings__DefaultConnection=

# Optional: second fallback only when ConnectionStrings:DefaultConnection is still empty in Development
# (same string as above if you need it; otherwise leave empty)
# Yamore__Development__DefaultConnection=

# --- RabbitMQ (API = publisher, Worker = consumer) ---
RabbitMQ__HostName=localhost
RabbitMQ__Port=5672
RabbitMQ__UserName=guest
RabbitMQ__Password=guest
RabbitMQ__VirtualHost=/
RabbitMQ__QueueName=yamore-tasks

# --- Yamore.Worker: SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER_NAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_FROM_ADDRESS=
SMTP_FROM_DISPLAY_NAME=Yamore

# Same keys the Worker reads via IConfiguration (Smtp:Host) — you can set either style.
# Smtp__Host=
# Smtp__Port=587
# Smtp__UserName=
# Smtp__Password=
# Smtp__UseSsl=true
# Smtp__FromAddress=
# Smtp__FromDisplayName=Yamore

# --- Stripe (API) — for Docker, compose uses STRIPE_* below. For dotnet run, set these: ---
# Stripe__SecretKey=
# Stripe__PublishableKey=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Optional: Stripe signing secret for POST https://<api>/api/stripe/webhook (payment_intent.succeeded)
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- API: demo DB seed (optional) ---
# DEMO_NOTIFICATION_EMAIL=
# DemoSeed__NotificationEmail=

# --- API: JWT (HMAC signing; never commit real production keys) ---
# Must be at least 32 characters. `appsettings.json` does not store a secret.
# Set one of: JWT_SECRET (below) or Jwt__Secret. Do not use Jwt__SecretKey (wrong key; ignored).
# Example:  openssl rand -base64 32
JWT_SECRET=
# Optional (defaults in appsettings if unset):
# Jwt__Issuer=Yamore
# Jwt__Audience=Yamore.Clients
# Jwt__AccessTokenMinutes=60
# Jwt__RefreshTokenDays=14

# --- CORS: comma-separated origins. If unset, Development still allows any origin. ---
# Cors__AllowedOrigins=https://app.example.com,https://www.example.com

# --- API base URL (Flutter) is NOT read by .NET; use:
#   flutter run --dart-define=API_BASE_URL=http://10.0.2.2:5096
# and String.fromEnvironment('API_BASE_URL') in the app.
