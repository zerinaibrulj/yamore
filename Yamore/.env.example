# Copy this file to `.env` in the same folder as `docker-compose.yml`.
# Docker Compose loads `.env` for variable substitution. Do not commit `.env`.
#
# You do NOT need every variable below:
# - Stripe: only if you test card checkout (otherwise use Pay on arrival).
# - SMTP_*: only if you want Worker to send real emails (RabbitMQ still works without it).
# - DEMO_NOTIFICATION_EMAIL: optional; helps demo users receive mail after first DB seed.

# Demo seed (API): demo.admin / demo.owner / demo.user use this email (first seed only, or use SQL to update later).
DEMO_NOTIFICATION_EMAIL=zerinaibrulj26@gmail.com

# Stripe — https://dashboard.stripe.com/test/apikeys (optional for development)
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# SMTP — Yamore.Worker (optional). Leave SMTP_HOST empty to skip sending email.
# Gmail: use App Password, not your normal password. FROM usually = same as SMTP_USER_NAME.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER_NAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_FROM_ADDRESS=
SMTP_FROM_DISPLAY_NAME=Yamore
