# Copy to `.env` in this folder (same directory as docker-compose.yml).
# Docker Compose loads `.env` automatically for variable substitution.
# Do not commit `.env`.

# Stripe — https://dashboard.stripe.com/test/apikeys (use test keys for development)
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# SMTP — Yamore.Worker (reservation / payment emails). Leave SMTP_HOST empty to skip sending.
# Gmail: Host=smtp.gmail.com, Port=587, UserName=your@gmail.com, Password=App Password (not normal password)
# Outlook: smtp.office365.com, 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER_NAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
# Often must match the mailbox you authenticate as (e.g. same as SMTP_USER_NAME for Gmail)
SMTP_FROM_ADDRESS=
SMTP_FROM_DISPLAY_NAME=Yamore
